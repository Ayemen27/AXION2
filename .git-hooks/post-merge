#!/bin/bash

# ══════════════════════════════════════════════════════════════════════════════
# AXION Git Hook — Post-Merge
# يشتغل بعد كل merge لتحديث: dependencies, changelog
# ══════════════════════════════════════════════════════════════════════════════

echo ""
echo "🪝 Running post-merge hooks..."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# ── 1. Update Dependencies ────────────────────────────────────────────────────
echo "📦 Step 1/3: Checking for dependency updates..."

if git diff-tree -r --name-only --no-commit-id ORIG_HEAD HEAD | grep -q "package.json"; then
  echo "📦 package.json changed. Running npm install..."
  npm install
  echo "✅ Dependencies updated"
else
  echo "ℹ️  No dependency changes"
fi

# ── 2. Update Changelog ───────────────────────────────────────────────────────
echo "📝 Step 2/3: Updating changelog..."

if [ -f "CHANGELOG.md" ]; then
  # Get merge commit message
  MERGE_MSG=$(git log -1 --pretty=%B)
  
  # Check if this is a feature/fix merge
  if echo "$MERGE_MSG" | grep -qE "^(feat|fix|perf):"; then
    DATE=$(date +%Y-%m-%d)
    ENTRY="- ${MERGE_MSG} (${DATE})"
    
    # Add to CHANGELOG.md
    sed -i.bak "4i\\
${ENTRY}\\
" CHANGELOG.md
    
    rm CHANGELOG.md.bak
    
    echo "✅ Changelog updated"
  else
    echo "ℹ️  No changelog update needed"
  fi
else
  echo "ℹ️  No CHANGELOG.md file"
fi

# ── 3. Rebuild if needed ──────────────────────────────────────────────────────
echo "🏗️ Step 3/3: Checking if rebuild needed..."

if git diff-tree -r --name-only --no-commit-id ORIG_HEAD HEAD | grep -qE '\.(ts|tsx|js|jsx)$'; then
  if [ -f "package.json" ] && grep -q "\"build\"" package.json; then
    echo "🏗️ Source files changed. Rebuilding..."
    npm run build
    echo "✅ Rebuild complete"
  fi
else
  echo "ℹ️  No rebuild needed"
fi

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "✅ Post-merge hooks complete!"
echo ""
