# ══════════════════════════════════════════════════════════════════════════════
# AXION Git Management — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════

# ── Web Dashboard ─────────────────────────────────────────────────────────────
PORT=5000
REPO_PATH=/path/to/your/repository

# ── Backup System ─────────────────────────────────────────────────────────────
BACKUP_ENCRYPTION_KEY=change-me-to-32-character-key
BACKUP_STORAGE=s3  # s3, gdrive, dropbox

# AWS S3
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=axion-git-backups

# Google Drive (requires OAuth credentials JSON file)
GOOGLE_DRIVE_CREDENTIALS=/path/to/credentials.json

# Dropbox
DROPBOX_ACCESS_TOKEN=your-dropbox-token

# ── Notifications ─────────────────────────────────────────────────────────────

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=AXION Git <noreply@axion.com>
NOTIFY_EMAIL=admin@example.com

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-MnoPQRstuVWXyz
TELEGRAM_CHAT_ID=123456789

# ── Git Configuration ─────────────────────────────────────────────────────────
GIT_USER_NAME=Your Name
GIT_USER_EMAIL=your-email@example.com
